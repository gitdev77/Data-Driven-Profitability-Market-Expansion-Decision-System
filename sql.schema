-- Create Database
CREATE DATABASE IF NOT EXISTS market_analysis;
USE market_analysis;

-- Create Main Sales Table
CREATE TABLE IF NOT EXISTS amazon_sales (
    order_id VARCHAR(50),
    order_date DATE,
    status VARCHAR(50),
    fulfillment VARCHAR(50),
    sales_channel VARCHAR(50),
    ship_city VARCHAR(100),
    ship_state VARCHAR(100),
    ship_country VARCHAR(50),
    category VARCHAR(100),
    quantity INT,
    amount DECIMAL(10,2),
    b2b_flag VARCHAR(10)
);
